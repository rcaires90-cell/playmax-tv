{
  "routes": [
    { "src": "/checkout", "dest": "/checkout.html" },
    { "src": "/afiliados", "dest": "/afiliados.html" },
    { "src": "/criativos", "dest": "/criativos.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" }
      ]
    }
  ]
}
