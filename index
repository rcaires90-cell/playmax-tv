<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PlayMax TV — Programa de Afiliados</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Sora:wght@400;500;600;700;800&display=swap');

*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#06060a;--bg2:#0d0d14;--accent:#00e87b;--orange:#ff9f43;--purple:#7c5cfc;--pink:#ff6b9d;
  --txt:#f0f0f5;--txt2:#8888a0;--txt3:#55556a;--border:rgba(255,255,255,.06);
  --grad:linear-gradient(135deg,#ff9f43,#ff6b9d);
}
body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--txt);min-height:100vh;-webkit-font-smoothing:antialiased}

.bg-fx{position:fixed;inset:0;z-index:0;pointer-events:none;
  background:radial-gradient(circle at 30% 20%,rgba(255,159,67,.04)0%,transparent 50%),
  radial-gradient(circle at 70% 80%,rgba(255,107,157,.03)0%,transparent 50%)}

.page{position:relative;z-index:2;max-width:600px;margin:0 auto;padding:24px 16px 80px}

/* NAV */
nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:32px}
nav .logo{font-family:'Sora',sans-serif;font-weight:700;font-size:1.1rem}
nav .logo em{font-style:normal;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
nav a{color:var(--txt2);text-decoration:none;font-size:.85rem;font-weight:500}

/* HERO */
.hero{text-align:center;margin-bottom:40px}
.hero .emoji{font-size:3.5rem;margin-bottom:16px}
.hero h1{font-family:'Sora',sans-serif;font-size:clamp(1.6rem,5vw,2.2rem);font-weight:800;line-height:1.15;margin-bottom:10px}
.hero h1 span{color:var(--orange)}
.hero p{color:var(--txt2);font-size:.95rem;line-height:1.6}

/* CARDS */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:24px;margin-bottom:16px}
.card h2{font-family:'Sora',sans-serif;font-size:1.1rem;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:8px}

/* COMMISSION TABLE */
.comm-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:16px}
.comm-box{background:rgba(255,159,67,.05);border:1px solid rgba(255,159,67,.12);border-radius:12px;padding:16px 10px;text-align:center}
.comm-box .plan{font-size:.72rem;color:var(--txt3);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;font-weight:600}
.comm-box .value{font-family:'Sora',sans-serif;font-size:1.4rem;font-weight:700;color:var(--orange)}
.comm-box .per{font-size:.68rem;color:var(--txt3);margin-top:2px}

.example{background:rgba(0,0,0,.3);border-radius:10px;padding:14px;font-size:.84rem;color:var(--txt2);line-height:1.7}
.example strong{color:var(--orange)}

/* HOW IT WORKS */
.steps-list{display:flex;flex-direction:column;gap:14px}
.step-item{display:flex;gap:14px;align-items:flex-start}
.step-num{width:36px;height:36px;border-radius:50%;background:rgba(255,159,67,.1);color:var(--orange);display:flex;align-items:center;justify-content:center;font-family:'Sora',sans-serif;font-weight:700;font-size:.85rem;flex-shrink:0}
.step-item .info h4{font-size:.92rem;font-weight:600;margin-bottom:2px}
.step-item .info p{font-size:.82rem;color:var(--txt2);line-height:1.5}

/* FORM */
.form-section{margin-top:16px}
.input-g{margin-bottom:14px}
.input-g label{display:block;font-size:.72rem;font-weight:600;color:var(--txt2);margin-bottom:6px;text-transform:uppercase;letter-spacing:1px}
.input-g input{width:100%;padding:14px 16px;background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:12px;color:var(--txt);font-family:inherit;font-size:.9rem;outline:none;transition:border-color .3s}
.input-g input:focus{border-color:var(--orange)}
.input-g input::placeholder{color:var(--txt3)}
.input-g .hint{font-size:.7rem;color:var(--txt3);margin-top:4px}

.btn-register{display:block;width:100%;padding:16px;background:var(--orange);color:#000;font-family:inherit;font-weight:700;font-size:1rem;border:none;border-radius:100px;cursor:pointer;transition:all .3s;margin-top:8px}
.btn-register:hover{box-shadow:0 8px 30px rgba(255,159,67,.3);transform:translateY(-1px)}
.btn-register:disabled{opacity:.4;pointer-events:none}

/* RESULT */
.result{display:none;text-align:center}
.result.show{display:block}
.result .check{font-size:3rem;margin-bottom:12px}
.result h3{font-family:'Sora',sans-serif;font-size:1.3rem;margin-bottom:8px}
.result .sub{color:var(--txt2);font-size:.88rem;margin-bottom:24px}

.link-box{background:rgba(255,159,67,.06);border:1.5px solid rgba(255,159,67,.2);border-radius:12px;padding:16px;margin-bottom:16px}
.link-box label{font-size:.7rem;text-transform:uppercase;letter-spacing:1px;color:var(--txt3);font-weight:600;margin-bottom:6px;display:block}
.link-box .link-row{display:flex;gap:8px;align-items:center}
.link-box input{flex:1;padding:10px 14px;background:rgba(0,0,0,.3);border:1px solid var(--border);border-radius:8px;color:var(--orange);font-family:'Sora',sans-serif;font-size:.82rem;font-weight:600;outline:none}
.link-box .copy{padding:10px 18px;background:var(--orange);color:#000;border:none;border-radius:8px;font-family:inherit;font-size:.78rem;font-weight:600;cursor:pointer;transition:all .3s;white-space:nowrap}
.link-box .copy:hover{box-shadow:0 4px 16px rgba(255,159,67,.3)}

.share-btns{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap}
.share-btn{flex:1;min-width:120px;padding:12px;border-radius:100px;font-family:inherit;font-weight:600;font-size:.82rem;border:none;cursor:pointer;transition:all .3s;text-align:center;text-decoration:none;display:flex;align-items:center;justify-content:center;gap:6px}
.share-btn.wa{background:#25d366;color:#fff}
.share-btn.wa:hover{box-shadow:0 4px 16px rgba(37,211,102,.3)}
.share-btn.ig{background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);color:#fff}
.share-btn.cp{background:rgba(255,255,255,.06);color:var(--txt);border:1px solid var(--border)}

.comm-table{width:100%;border-collapse:collapse;margin-top:12px}
.comm-table th{font-size:.7rem;text-transform:uppercase;letter-spacing:1px;color:var(--txt3);font-weight:600;padding:8px;text-align:left;border-bottom:1px solid var(--border)}
.comm-table td{font-size:.84rem;padding:10px 8px;border-bottom:1px solid var(--border);color:var(--txt2)}
.comm-table td:last-child{color:var(--orange);font-weight:600;font-family:'Sora',sans-serif}

@media(max-width:400px){
  .comm-grid{grid-template-columns:1fr}
  .share-btns{flex-direction:column}
}
</style>
</head>
<body>
<div class="bg-fx"></div>

<div class="page">
  <nav>
    <div class="logo"><em>PlayMax</em> TV</div>
    <a href="https://playmax-tv.vercel.app">← Ver planos</a>
  </nav>

  <!-- HERO -->
  <div class="hero">
    <div class="emoji">💰</div>
    <h1>Ganhe dinheiro<br><span>indicando TV</span></h1>
    <p>Seja afiliado PlayMax TV e receba comissão por cada venda que fizer. Sem investimento, sem estoque.</p>
  </div>

  <!-- FORM SECTION -->
  <div id="formSection">

    <!-- COMISSÕES -->
    <div class="card">
      <h2>💰 Suas comissões</h2>
      <div class="comm-grid">
        <div class="comm-box">
          <div class="plan">Básico</div>
          <div class="value">R$8,99</div>
          <div class="per">/mês por 3 meses</div>
        </div>
        <div class="comm-box">
          <div class="plan">Premium</div>
          <div class="value">R$13,49</div>
          <div class="per">/mês por 3 meses</div>
        </div>
        <div class="comm-box">
          <div class="plan">Família</div>
          <div class="value">R$17,99</div>
          <div class="per">/mês por 3 meses</div>
        </div>
      </div>
      <div class="example">
        <strong>Exemplo:</strong> Se você fizer 10 vendas do plano Premium num mês, ganha <strong>R$13,49 × 10 × 3 meses = R$404,70</strong> de comissão total!
      </div>
    </div>

    <!-- COMO FUNCIONA -->
    <div class="card">
      <h2>🔄 Como funciona</h2>
      <div class="steps-list">
        <div class="step-item">
          <div class="step-num">1</div>
          <div class="info">
            <h4>Cadastre-se aqui</h4>
            <p>Preencha seu nome e WhatsApp abaixo</p>
          </div>
        </div>
        <div class="step-item">
          <div class="step-num">2</div>
          <div class="info">
            <h4>Receba seu link exclusivo</h4>
            <p>Um link personalizado só seu pra rastrear as vendas</p>
          </div>
        </div>
        <div class="step-item">
          <div class="step-num">3</div>
          <div class="info">
            <h4>Divulgue pra todo mundo</h4>
            <p>Compartilhe nas redes sociais, grupos e pra amigos</p>
          </div>
        </div>
        <div class="step-item">
          <div class="step-num">4</div>
          <div class="info">
            <h4>Ganhe comissão</h4>
            <p>15% em cada venda, nos 3 primeiros meses do cliente</p>
          </div>
        </div>
      </div>
    </div>

    <!-- FORMULÁRIO -->
    <div class="card">
      <h2>📝 Cadastrar como afiliado</h2>
      <div class="form-section">
        <div class="input-g">
          <label>Seu nome</label>
          <input type="text" id="affName" placeholder="Como quer ser chamado" oninput="checkForm()">
        </div>
        <div class="input-g">
          <label>WhatsApp (com DDD)</label>
          <input type="tel" id="affPhone" placeholder="(11) 99999-9999" oninput="checkForm()">
        </div>
        <div class="input-g">
          <label>Instagram (opcional)</label>
          <input type="text" id="affInsta" placeholder="@seuarroba">
        </div>
        <button class="btn-register" id="btnRegister" disabled onclick="register()">Quero ser afiliado! 🚀</button>
      </div>
    </div>
  </div>

  <!-- RESULTADO -->
  <div class="result" id="resultSection">
    <div class="check">✅</div>
    <h3>Cadastro enviado!</h3>
    <div class="sub">Aqui está seu link de afiliado. Compartilhe e comece a ganhar!</div>

    <div class="link-box">
      <label>Seu link exclusivo</label>
      <div class="link-row">
        <input type="text" id="affLink" readonly>
        <button class="copy" onclick="copyLink()">Copiar</button>
      </div>
    </div>

    <div class="share-btns">
      <a id="shareWa" class="share-btn wa" target="_blank">📲 WhatsApp</a>
      <button class="share-btn cp" onclick="copyLink()">📋 Copiar link</button>
    </div>

    <div class="card" style="text-align:left">
      <h2>📊 Tabela de ganhos</h2>
      <table class="comm-table">
        <thead><tr><th>Vendas/mês</th><th>Plano</th><th>Ganho (3 meses)</th></tr></thead>
        <tbody>
          <tr><td>5 vendas</td><td>Premium</td><td>R$202,35</td></tr>
          <tr><td>10 vendas</td><td>Premium</td><td>R$404,70</td></tr>
          <tr><td>20 vendas</td><td>Premium</td><td>R$809,40</td></tr>
          <tr><td>50 vendas</td><td>Mix</td><td>R$2.000+</td></tr>
        </tbody>
      </table>
    </div>

    <div class="card" style="text-align:left;margin-top:16px">
      <h2>📋 Mensagem pronta pra divulgar</h2>
      <div style="background:rgba(0,0,0,.3);padding:14px;border-radius:10px;font-size:.84rem;color:var(--txt2);line-height:1.7;white-space:pre-line;position:relative" id="promoMsg">
Fala! Conhece a PlayMax TV? 📺

Mais de 2.300 canais ao vivo, filmes, séries e muito mais — tudo por a partir de R$59,90/mês!

✅ Funciona em Smart TV, celular, TV Box
✅ Ativação em 5 minutos
✅ Teste grátis de 6 horas

Assina pelo meu link e garanta o melhor preço:
👉 [SEU LINK AQUI]

Qualquer dúvida, me chama! 😉</div>
      <button style="margin-top:10px;padding:8px 18px;background:rgba(255,255,255,.06);border:1px solid var(--border);color:var(--txt2);font-family:inherit;font-size:.78rem;border-radius:100px;cursor:pointer" onclick="copyPromo()">📋 Copiar mensagem</button>
    </div>

    <a href="https://playmax-criativos.vercel.app" target="_blank" class="card" style="display:block;text-decoration:none;margin-top:16px;border-color:rgba(0,232,123,.2);background:rgba(0,232,123,.03)">
      <h2 style="justify-content:center">🎨 Acessar Gerador de Criativos</h2>
      <p style="font-size:.84rem;color:var(--txt2);text-align:center;line-height:1.5">Posts, Stories e Reels prontos pra baixar e postar todo dia. Material completo de divulgação!</p>
    </a>
  </div>
</div>

<script>
const SITE_URL = 'https://playmax-tv.vercel.app'; // Trocar pela URL real da Vercel
const WHATSAPP = '5511914164272';

function checkForm() {
  const n = document.getElementById('affName').value.trim();
  const p = document.getElementById('affPhone').value.trim();
  document.getElementById('btnRegister').disabled = !(n.length > 2 && p.length > 8);
}

function register() {
  const name = document.getElementById('affName').value.trim();
  const phone = document.getElementById('affPhone').value.trim().replace(/\D/g,'');
  const insta = document.getElementById('affInsta').value.trim();

  // Generate affiliate code from name
  const code = name.toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g,'')
    .replace(/[^a-z0-9]/g,'')
    .substring(0,10)
    + Math.floor(Math.random()*100);

  const link = `${SITE_URL}?ref=${code}`;

  // Show result
  document.getElementById('formSection').style.display = 'none';
  document.getElementById('resultSection').classList.add('show');
  document.getElementById('affLink').value = link;

  // Update promo message with link
  const promo = document.getElementById('promoMsg');
  promo.textContent = promo.textContent.replace('[SEU LINK AQUI]', link);

  // WhatsApp share
  const waMsg = encodeURIComponent(
    `Olá! Me cadastrei como afiliado PlayMax TV.\n\nNome: ${name}\nWhatsApp: ${phone}\n${insta ? 'Instagram: '+insta+'\n' : ''}Código: ${code}\n\nAguardo confirmação!`
  );
  document.getElementById('shareWa').href = `https://wa.me/${WHATSAPP}?text=${waMsg}`;

  // Auto send registration to owner via WhatsApp (open in new tab)
  window.open(`https://wa.me/${WHATSAPP}?text=${waMsg}`, '_blank');
}

function copyLink() {
  const input = document.getElementById('affLink');
  navigator.clipboard.writeText(input.value).then(() => {
    const btns = document.querySelectorAll('.copy');
    btns.forEach(b => { b.textContent = 'Copiado!'; setTimeout(() => b.textContent = 'Copiar', 2000); });
  });
}

function copyPromo() {
  const text = document.getElementById('promoMsg').textContent;
  navigator.clipboard.writeText(text);
  event.target.textContent = '✅ Copiado!';
  setTimeout(() => event.target.textContent = '📋 Copiar mensagem', 2000);
}
</script>
</body>
</html>
